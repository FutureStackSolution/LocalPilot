<Window x:Class="LocalPilot.UI.InlineChatOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalPilot Inline"
        Height="80" Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        BorderThickness="0">
    
    <Grid>
        <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" 
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                BorderThickness="1" 
                CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" Color="Black" Opacity="0.2" ShadowDepth="1"/>
            </Border.Effect>
            
            <Grid Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="LocalPilot Inline" 
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" 
                               FontSize="10" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" (Enter to run, Esc to cancel)" 
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" 
                               FontSize="9" 
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <TextBox x:Name="InputBox"
                             Background="Transparent"
                             Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                             BorderThickness="0"
                             CaretBrush="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             Padding="4,0"
                             KeyDown="InputBox_KeyDown"
                             AcceptsReturn="False"/>
                    
                    <TextBlock x:Name="Placeholder"
                               Text="Try: '/explain', '/fix', or 'optimize this loop'..."
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               FontSize="13"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               Visibility="Visible"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
