<Window x:Class="LocalPilot.UI.InlineChatOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalPilot Inline"
        Height="80" Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        BorderThickness="0">
    
    <Window.Resources>
        <Color x:Key="OverlayBgColor">#1E1E1E</Color>
        <Color x:Key="AccentColor">#2D8CFF</Color>
    </Window.Resources>

    <Grid>
        <Border Background="#212121" 
                BorderBrush="#444444" 
                BorderThickness="1" 
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.5" ShadowDepth="2"/>
            </Border.Effect>
            
            <Grid Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="LocalPilot summon" 
                               Foreground="#AAAAAA" 
                               FontSize="10" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" (Enter to apply, Esc to cancel)" 
                               Foreground="#666666" 
                               FontSize="9" 
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <TextBox x:Name="InputBox"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             CaretBrush="#2D8CFF"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             Padding="4,0"
                             KeyDown="InputBox_KeyDown"
                             AcceptsReturn="False"/>
                    
                    <TextBlock x:Name="Placeholder"
                               Text="Try: 'add unit tests' or 'optimize this loop'..."
                               Foreground="#555555"
                               FontSize="13"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               Visibility="Visible"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
