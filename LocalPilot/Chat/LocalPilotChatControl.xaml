<UserControl x:Class="LocalPilot.Chat.LocalPilotChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
             FontFamily="Segoe UI" FontSize="13">

    <UserControl.Resources>
        <!-- ═══ Theme Colors (Dynamic mapping to VS Shell) ═══ -->
        <SolidColorBrush x:Key="LpWindowBgBrush"      Color="Transparent"/>
        <SolidColorBrush x:Key="LpWindowFgBrush"      Color="Transparent"/>
        <SolidColorBrush x:Key="LpMenuBgBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpMenuBorderBrush"    Color="Transparent"/>
        <SolidColorBrush x:Key="LpHoverBgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpHoverFgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpMutedFgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpAccentBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpUserBubbleBgBrush"  Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeKwBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeCommentBrush"   Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeStringBrush"    Color="Transparent"/>
        <SolidColorBrush x:Key="LpAntigravityBlue"   Color="#2D8CFF"/>

        <!-- ═══ Minimalist Scrollbar ═══ -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width"      Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="Transparent"/>
            </Style.Resources>
        </Style>

        <!-- ═══ Professional Button Style — clean, borderless, theme-aware hover ═══ -->
        <Style x:Key="LpButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Ghost Icon Button (Sexy & Professional) ═══ -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Margin"          Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="4">
                            <ContentPresenter x:Name="Cp" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1" CenterX="12" CenterY="12"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="Cp" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="14" CenterY="14"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Modern Chat Input — sleek border, integrated look ═══ -->
        <Style x:Key="ChatInputStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,11"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="0"
                                      Background="Transparent"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Context Menu (Themed) ────────────────────────────────── -->
        <Style x:Key="ThemedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource LpMenuBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ItemsPresenter Margin="0,4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                            <Grid Margin="1,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" SharedSizeGroup="IconGroup"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon Column -->
                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="4,0"/>

                                <!-- Header Content -->
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Margin="8,4,20,4"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpAccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpMutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Opacity"    Value="0.8"/>
        </Style>

        <!-- ── Send Button (Premium Glow Aesthetic) ─────────────────────── -->
        <!-- 💼 Premium Work Summary Styles -->
        <Style x:Key="WorkSummaryHeaderStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LpMenuBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkRowStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,4,8,4"/> <!-- Indented for hierarchy -->
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LpMenuBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🚀 Updated Send/Action Styles -->
        <Style x:Key="LpSendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource LpAntigravityBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="11"> <!-- Perfect Circle -->
                            <ContentPresenter x:Name="Cp" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                                 <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="SendScale" ScaleX="1" ScaleY="1" CenterX="14" CenterY="14"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="1.0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#3a96ff"/> <!-- Slightly brighter on hover -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="Cp" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" CenterX="16" CenterY="16"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpMutedFgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Confirmation Buttons (Enterprise) ───────────────────────── -->
        <Style x:Key="LpPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LpButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LpButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpModeButtonStyle" TargetType="Button" BasedOn="{StaticResource LpButtonStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="{DynamicResource LpWindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Messages -->
            <RowDefinition Height="Auto"/>  <!-- Footer / Input -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════  HEADER  ═══════════════════════════════ -->
        <!-- Flat, VS-native header — no border radius, just a bottom divider -->
        <Border Grid.Row="0"
                Background="{DynamicResource LpMenuBgBrush}"
                BorderBrush="{DynamicResource LpMenuBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/LocalPilot;component/Assets/Logo_Concept_Minimalist.png"
                           Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="LocalPilot"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource LpWindowFgBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>

                </StackPanel>

                <!-- Right: icon buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnClear"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Clear conversation"
                            Click="BtnClear_Click">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource LpMutedFgBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════  MESSAGES  ══════════════════════════════ -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <StackPanel Margin="0,6,0,6">

                <!-- Welcome prompt — Copilot style: subtle, centred, muted -->
                <TextBlock Text="What's on your mind?"
                           FontSize="12"
                           Foreground="{DynamicResource LpMutedFgBrush}"
                           Margin="24,12,24,8"
                           Opacity="0.85"
                           TextWrapping="Wrap"/>

                <!-- All messages rendered here -->
                <StackPanel x:Name="MessagesContainer" VerticalAlignment="Top"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════  FOOTER  ════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource LpMenuBgBrush}"
                BorderBrush="{DynamicResource LpMenuBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10,14,6">
            <StackPanel>

                <!-- Agent status row — inline, minimal -->
                <Border x:Name="AgentStatusBar"
                        Visibility="Collapsed"
                        Margin="2,0,2,10"
                        Padding="10,6"
                        Background="{DynamicResource LpWindowBgBrush}"
                        BorderBrush="{DynamicResource LpMenuBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource LpAccentBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsVisible" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseAnimation">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.4" Duration="0:0:0.8"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.2" Duration="0:0:0.8"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.2" Duration="0:0:0.8"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="PulseAnimation"/>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock x:Name="TxtAgentStatus"
                                   Text="LocalPilot working"
                                   Foreground="{DynamicResource LpWindowFgBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtDots"
                                   Text="..."
                                   Foreground="{DynamicResource LpWindowFgBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Width="20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsVisible" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard x:Name="DotsStoryboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <StringAnimationUsingKeyFrames Storyboard.TargetProperty="Text" Duration="0:0:1.5">
                                                            <DiscreteStringKeyFrame Value="" KeyTime="0:0:0"/>
                                                            <DiscreteStringKeyFrame Value="." KeyTime="0:0:0.375"/>
                                                            <DiscreteStringKeyFrame Value=".." KeyTime="0:0:0.75"/>
                                                            <DiscreteStringKeyFrame Value="..." KeyTime="0:0:1.125"/>
                                                        </StringAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="DotsStoryboard"/>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock x:Name="TxtAgentDetail"
                                   Text=""
                                   Foreground="{DynamicResource LpMutedFgBrush}"
                                   FontSize="10"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Premium Antigravity Confirmation Panel -->
                <Border x:Name="ConfirmationPanel"
                        Background="{DynamicResource LpMenuBgBrush}"
                        BorderBrush="{DynamicResource LpMenuBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="Collapsed"
                        Padding="16,14"
                        Margin="0,0,0,10">
                    <StackPanel Orientation="Vertical">
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource LpAccentBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Confirm Action"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource LpWindowFgBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <Border Background="{DynamicResource LpWindowBgBrush}"
                                BorderBrush="{DynamicResource LpMenuBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,10">
                            <TextBlock x:Name="TxtConfirmDetail"
                                       Text="The agent is requesting permission to continue."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource LpWindowFgBrush}"
                                       Opacity="0.95"
                                       FontSize="12"
                                       LineHeight="18"
                                       FontFamily="Segoe UI"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button x:Name="BtnDeny" Content="Cancel" Click="BtnDeny_Click" Style="{StaticResource LpSecondaryActionButtonStyle}" Margin="0,0,10,0"/>
                            <Button x:Name="BtnApprove" Content="Allow" Click="BtnApprove_Click" Style="{StaticResource LpPrimaryActionButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Input row: TextBox + Send button area -->
                <Border Background="{DynamicResource LpWindowBgBrush}"
                        BorderBrush="{DynamicResource LpMenuBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="6,6,6,6">
                <Grid>
                    <TextBox x:Name="TxtInput"
                             Style="{StaticResource ChatInputStyle}"
                             MinHeight="44" MaxHeight="160"
                             Padding="12,12,65,12"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             PreviewKeyDown="TxtInput_PreviewKeyDown"
                             FontSize="13"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2">
                        <!-- Quick Actions Left of Send -->
                        <Button x:Name="BtnQuickActions"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Quick Actions"
                                Click="BtnQuickActions_Click"
                                Margin="0,0,1,1"> 
                            <TextBlock Text="&#xE945;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="10" 
                                       Foreground="{DynamicResource LpMutedFgBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="QuickActionsMenu" Style="{StaticResource ThemedContextMenuStyle}">
                                    <MenuItem x:Name="MenuExplain" Header="Explain Code" Tag="explain" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                        <MenuItem.Icon><TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource LpWindowFgBrush}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="MenuRefactor" Header="Refactor Code" Tag="refactor" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                        <MenuItem.Icon><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource LpWindowFgBrush}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="MenuDoc" Header="Generate Docs" Tag="document" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                        <MenuItem.Icon><TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource LpWindowFgBrush}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="MenuReview" Header="Code Review" Tag="review" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                        <MenuItem.Icon><TextBlock Text="&#xE928;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource LpWindowFgBrush}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="MenuFix" Header="Fix Issues" Tag="fix" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                        <MenuItem.Icon><TextBlock Text="&#xEA8A;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource LpWindowFgBrush}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="MenuTest" Header="Generate Tests" Tag="test" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                        <MenuItem.Icon><TextBlock Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource LpWindowFgBrush}"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        
                        <!-- Send Button -->
                        <Button x:Name="BtnSend"
                                Style="{StaticResource LpSendButtonStyle}"
                                Click="BtnSend_Click"
                                ToolTip="Send (Enter)"
                                Margin="1,0,3,1"> 
                            <Path x:Name="BtnSendIcon"
                                  Data="M3.4,20.4l17.45-7.48c0.81-0.35,0.81-1.49,0-1.84L3.4,3.6C2.71,3.3,2,3.8,2,4.55l1.6,7.45L2,19.45C2,20.2,2.71,20.7,3.4,20.4z"
                                  Fill="White"
                                  Width="8" Height="8"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Margin="1,0,0,0"/>
                        </Button>
                    </StackPanel>
                </Grid>
                </Border>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
