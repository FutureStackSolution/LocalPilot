<UserControl x:Class="LocalPilot.Chat.LocalPilotChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             FontFamily="Segoe UI" FontSize="13">

    <UserControl.Resources>
        <!-- Design Tokens -->
        <SolidColorBrush x:Key="LpAccentColor"   Color="#7C6AF7"/>
        <SolidColorBrush x:Key="LpAccentHover"   Color="#9B8FFB"/>
        <Thickness x:Key="BubblePadding">14,10,14,10</Thickness>

        <!-- Custom Scrollbar Style -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="Transparent" />
            </Style.Resources>
        </Style>

        <!-- Send Button -->
        <Style x:Key="SendBtnStyle" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource {x:Static vsshell:VsBrushes.TitleBarActiveGradientBeginKey}}"/>
            <Setter Property="Foreground"       Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Width"            Value="36"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonFaceKey}}"/>
                                <Setter Property="Opacity"    Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Action Chip -->
        <Style x:Key="ActionChipStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource {x:Static vsshell:VsBrushes.ButtonFaceKey}}"/>
            <Setter Property="Foreground"      Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#7C6AF7"/>
                                <Setter Property="Foreground" Value="#7C6AF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#207C6AF7"/>
                                <Setter Property="Foreground" Value="#7C6AF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chat Input TextBox -->
        <Style x:Key="ChatInputStyle" TargetType="TextBox">
            <Setter Property="Background"       Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBackgroundKey}}"/>
            <Setter Property="Foreground"       Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBorderKey}}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,10"/>
            <Setter Property="AcceptsReturn"    Value="True"/>
            <Setter Property="TextWrapping"     Value="Wrap"/>
            <Setter Property="CaretBrush"       Value="#7C6AF7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#7C6AF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Main Header -->
            <RowDefinition Height="*"/>    <!-- Messages (Scrollable) -->
            <RowDefinition Height="Auto"/> <!-- Footer / Input -->
        </Grid.RowDefinitions>

        <!-- ═══ Sleek Header ═════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientBeginKey}}"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}"
                BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/LocalPilot;component/Assets/Logo_Concept_Minimalist.png" 
                           Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="LocalPilot" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnClear" Style="{StaticResource IconButtonStyle}"
                            ToolTip="Clear conversation"
                            Click="BtnClear_Click">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Scrollable Message Area ═══════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <StackPanel Margin="16,8,16,8">
                <!-- Welcome Message only shows at the start of history -->
                <TextBlock Text="What's on your mind?"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                           Margin="0,8,0,16" Opacity="0.7"/>

                <StackPanel x:Name="MessagesContainer" VerticalAlignment="Top"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Footer / Input Area ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="Transparent" Padding="12,4,12,16">
            <StackPanel>
                <!-- Quick Actions Pinned at Bottom -->
                <StackPanel Orientation="Horizontal" Margin="4,0,0,8">
                    <Button x:Name="BtnQuickActions" Style="{StaticResource IconButtonStyle}"
                            ToolTip="Quick Actions"
                            Click="BtnQuickActions_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Quick Actions" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Explain Code" Tag="explain" Click="MenuQuickAction_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" 
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Refactor Code" Tag="refactor" Click="MenuQuickAction_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Generate Documentation" Tag="document" Click="MenuQuickAction_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Code Review" Tag="review" Click="MenuQuickAction_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE928;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Fix Issues" Tag="fix" Click="MenuQuickAction_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xEA8A;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Generate Unit Tests" Tag="test" Click="MenuQuickAction_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
                
                <!-- Streaming Status / Thinking Indicator -->
                <Border x:Name="StreamingBar" Visibility="Collapsed" Margin="4,0,4,12"
                        BorderThickness="1" BorderBrush="#207C6AF7"
                        Background="#087C6AF7" CornerRadius="6" Padding="10,6">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <!-- Pulsing Lightning Bolt -->
                            <TextBlock Text="&#xEBD2;" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="12" Foreground="#7C6AF7" 
                                       VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform CenterX="6" CenterY="6"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Visibility, ElementName=StreamingBar}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             From="0.85" To="1.2" Duration="0:0:0.7"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             From="0.85" To="1.2" Duration="0:0:0.7"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0.4" To="1.0" Duration="0:0:0.7"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="LocalPilot is thinking" 
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                       FontSize="11" VerticalAlignment="Center" Opacity="0.8"/>

                            <TextBlock x:Name="ThinkingDots" 
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                       FontSize="11" VerticalAlignment="Center" Opacity="0.8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Visibility, ElementName=StreamingBar}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="DotsAnim">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <StringAnimationUsingKeyFrames Storyboard.TargetProperty="Text" Duration="0:0:1.5">
                                                                <DiscreteStringKeyFrame Value="." KeyTime="0:0:0.0" />
                                                                <DiscreteStringKeyFrame Value=".." KeyTime="0:0:0.5" />
                                                                <DiscreteStringKeyFrame Value="..." KeyTime="0:0:1.0" />
                                                            </StringAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="DotsAnim"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Button x:Name="BtnStop" Content="Stop" HorizontalAlignment="Right"
                                Foreground="#F44747" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" FontSize="11" Click="BtnStop_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main Input Grid -->
                <Grid>
                    <TextBox x:Name="TxtInput"
                             Style="{StaticResource ChatInputStyle}"
                             MinHeight="44" MaxHeight="150"
                             Padding="12,10,40,10"
                             AcceptsReturn="False"
                             VerticalContentAlignment="Top"
                             KeyDown="TxtInput_KeyDown">
                        <TextBox.Resources>
                            <!-- Resources for TextBox -->
                        </TextBox.Resources>
                    </TextBox>

                    <Button x:Name="BtnSend"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Send message (Enter)"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Width="32" Height="32"
                            Click="BtnSend_Click">
                        <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
