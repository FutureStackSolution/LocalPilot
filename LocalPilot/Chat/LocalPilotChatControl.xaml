<UserControl x:Class="LocalPilot.Chat.LocalPilotChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
             FontFamily="Segoe UI" FontSize="13">

    <UserControl.Resources>
        <!-- ═══ Theme Colors (Dynamic mapping to VS Shell) ═══ -->
        <SolidColorBrush x:Key="LpWindowBgBrush"      Color="Transparent"/>
        <SolidColorBrush x:Key="LpWindowFgBrush"      Color="Transparent"/>
        <SolidColorBrush x:Key="LpMenuBgBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpMenuBorderBrush"    Color="Transparent"/>
        <SolidColorBrush x:Key="LpHoverBgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpHoverFgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpMutedFgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpAccentBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpAccentHoverBrush"   Color="Transparent"/>
        <SolidColorBrush x:Key="LpUserBubbleBgBrush"  Color="Transparent"/>
        <SolidColorBrush x:Key="LpConsoleBgBrush"     Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeKwBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeCommentBrush"   Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeStringBrush"    Color="Transparent"/>
        <SolidColorBrush x:Key="LpAntigravityBlue"   Color="#2D8CFF"/>
        
        <!-- 💎 Ghost Engine Glass Tokens -->
        <SolidColorBrush x:Key="LpGlassBgBrush"       Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="LpGlassBorderBrush"   Color="#25FFFFFF"/>
        <DropShadowEffect x:Key="LpGhostShadow"       BlurRadius="8" ShadowDepth="0" Color="Black" Opacity="0.18"/>
        <SolidColorBrush x:Key="LpTimelineLineBrush" Color="#33FFFFFF"/>

        <!-- ═══ Minimalist Scrollbar ═══ -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width"      Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="Transparent"/>
            </Style.Resources>
        </Style>

        <!-- ═══ Professional Button Style — clean, borderless, theme-aware hover ═══ -->
        <Style x:Key="LpButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Ghost Icon Button (Sexy & Professional) ═══ -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Margin"          Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="4">
                            <ContentPresenter x:Name="Cp" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1" CenterX="12" CenterY="12"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="Cp" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="14" CenterY="14"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Modern Chat Input — sleek border, integrated look ═══ -->
        <Style x:Key="ChatInputStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,11"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="0"
                                      Background="Transparent"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Context Menu (Themed) ────────────────────────────────── -->
        <Style x:Key="ThemedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource LpMenuBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ItemsPresenter Margin="0,4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                            <Grid Margin="1,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" SharedSizeGroup="IconGroup"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon Column -->
                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="4,0"/>

                                <!-- Header Content -->
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Margin="8,4,20,4"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpAccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpMutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Opacity"    Value="1.0"/>
        </Style>

        <!-- ── Send Button (Premium Glow Aesthetic) ─────────────────────── -->
        <!-- 💼 Premium Work Summary Styles -->
        <Style x:Key="WorkSummaryHeaderStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LpMenuBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkRowStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,4,8,4"/> <!-- Indented for hierarchy -->
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LpMenuBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🚀 Updated Send/Action Styles -->
        <Style x:Key="LpSendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource LpAntigravityBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15"> <!-- Balanced Circle -->
                            <ContentPresenter x:Name="Cp" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                                 <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="SendScale" ScaleX="1" ScaleY="1" CenterX="15" CenterY="15"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="1.0"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpAccentHoverBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="Cp" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" CenterX="16" CenterY="16"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpMutedFgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Confirmation Buttons (Enterprise) ───────────────────────── -->
        <Style x:Key="LpPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LpButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LpButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🏛️ Chronicle Styles (Hierarchical Activity Timeline) -->
        <Style x:Key="ActionNodeStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource LpGlassBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpGlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <Style x:Key="ActionNodeIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource LpAccentBrush}"/>
        </Style>

        <Style x:Key="ActionNodeHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource LpMutedLabel}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="Opacity" Value="1.0"/>
        </Style>

        <!-- 🌊 Delta Staging Card Styles -->
        <Style x:Key="DeltaCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,12,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource LpGlassBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpGlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource LpGhostShadow}"/>
        </Style>

        <Style x:Key="DeltaCodeStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Lucida Console, monospace"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <!-- 🏷️ Ghost Chip Style (Modern & Interactive) -->
        <Style x:Key="LpChipStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource LpGlassBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource LpGlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpGlassBorderBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource LpAccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="{DynamicResource LpWindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Messages -->
            <RowDefinition Height="Auto"/>  <!-- Footer / Input -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════  HEADER  ═══════════════════════════════ -->
        <!-- Flat, VS-native header — no border radius, just a bottom divider -->
        <Border Grid.Row="0"
                Background="{DynamicResource LpMenuBgBrush}"
                BorderBrush="{DynamicResource LpMenuBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/LocalPilot;component/Assets/Logo_Concept_Minimalist.png"
                           Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="LocalPilot"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource LpWindowFgBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>

                </StackPanel>

                <!-- Right: icon buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnToggleConsole"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Toggle Diagnostic Console"
                            Click="BtnToggleConsole_Click">
                        <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource LpMutedFgBrush}"/>
                    </Button>
                    <Button x:Name="BtnClear"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Clear conversation"
                            Click="BtnClear_Click">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource LpMutedFgBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════  MESSAGES  ══════════════════════════════ -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <StackPanel Margin="0,6,0,6">

                <!-- Welcome prompt — Copilot style: subtle, centred, muted -->
                <TextBlock Text="What's on your mind?"
                           FontSize="12"
                           Foreground="{DynamicResource LpMutedFgBrush}"
                           Margin="24,12,24,8"
                           Opacity="0.85"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Tip: use slash actions like /explain, /fix, /review, or /test."
                           FontSize="10"
                           Foreground="{DynamicResource LpMutedFgBrush}"
                           Margin="24,0,24,10"
                           Opacity="0.8"
                           TextWrapping="Wrap"/>
                <TextBlock Text="ACTIONS"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="{DynamicResource LpMutedFgBrush}"
                           Margin="20,0,20,6"
                           Opacity="0.85"/>

                <!-- Quick action shortcuts for discoverability -->
                <WrapPanel x:Name="QuickActionBar" Margin="20,0,20,10">
                    <Button Content="Explain Code" Tag="explain" ToolTip="Explain selected code" Click="QuickAction_Click" Style="{StaticResource LpChipStyle}"/>
                    <Button Content="Refactor Code" Tag="refactor" ToolTip="Refactor selected code" Click="QuickAction_Click" Style="{StaticResource LpChipStyle}"/>
                    <Button Content="Generate Documentation" Tag="document" ToolTip="Generate documentation from selected code" Click="QuickAction_Click" Style="{StaticResource LpChipStyle}"/>
                    <Button Content="Review Code" Tag="review" ToolTip="Review selected code for issues and improvements" Click="QuickAction_Click" Style="{StaticResource LpChipStyle}"/>
                    <Button Content="Fix Issues" Tag="fix" ToolTip="Fix issues in selected code" Click="QuickAction_Click" Style="{StaticResource LpChipStyle}"/>
                    <Button Content="Generate Unit Tests" Tag="test" ToolTip="Generate unit tests for selected code" Click="QuickAction_Click" Style="{StaticResource LpChipStyle}"/>
                </WrapPanel>

                <!-- All messages rendered here -->
                <StackPanel x:Name="MessagesContainer" VerticalAlignment="Top"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════  DIAGNOSTIC CONSOLE  ═══════════════════════ -->
        <!-- Collapsible terminal-like log view -->
        <Grid Grid.Row="1" VerticalAlignment="Bottom" MaxHeight="250">
            <Border x:Name="DiagnosticConsole"
                    Visibility="Collapsed"
                    Background="{DynamicResource LpMenuBgBrush}"
                    BorderBrush="{DynamicResource LpMenuBorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Console Header -->
                    <Border Grid.Row="0" Padding="8,4" Background="{DynamicResource LpWindowBgBrush}">
                        <DockPanel>
                            <TextBlock Text="DIAGNOSTIC CONSOLE" FontSize="9" FontWeight="Bold" 
                                       Foreground="{DynamicResource LpMutedFgBrush}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnCloseConsole" DockPanel.Dock="Right" 
                                    Style="{StaticResource IconButtonStyle}" 
                                    Width="16" Height="16" Click="BtnCloseConsole_Click">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <!-- Console Feed -->
                    <ScrollViewer Grid.Row="1" x:Name="ConsoleScroll" Padding="8" Background="{DynamicResource LpConsoleBgBrush}">
                        <StackPanel x:Name="ConsoleContainer">
                            <!-- Log entries will be added here -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════  FOOTER (GHOST HUD)  ═══════════════════════ -->
        <Grid Grid.Row="2">
            <StackPanel Margin="16,0,16,16">
                <!-- Status Bar (Chronicle Phase) -->
                <Border x:Name="AgentStatusBar" Visibility="Collapsed" Margin="8,0,8,12" Padding="12,8" 
                        Background="{DynamicResource LpMenuBgBrush}" CornerRadius="6" Effect="{StaticResource LpGhostShadow}"
                        BorderBrush="{DynamicResource LpGlassBorderBrush}" BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </Border.RenderTransform>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource LpAccentBrush}" Margin="4,0,12,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <Trigger Property="Visibility" Value="Visible">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.8" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock x:Name="TxtAgentStatus" Text="{Binding AgentTurn.StatusText}" Foreground="{DynamicResource LpWindowFgBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtAgentDetail" Text="{Binding AgentTurn.DetailText}" Foreground="{DynamicResource LpMutedFgBrush}" FontSize="11" Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                    </StackPanel>
                </Border>

                <!-- Confirmation Panel -->
                <Border x:Name="ConfirmationPanel" Visibility="Collapsed" Margin="0,0,0,12" Padding="16" 
                        Background="{DynamicResource LpMenuBgBrush}" CornerRadius="6" Effect="{StaticResource LpGhostShadow}"
                        BorderBrush="{DynamicResource LpGlassBorderBrush}" BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="APPROVAL"
                                   Foreground="{DynamicResource LpMutedFgBrush}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Permission Required" FontWeight="Bold" Foreground="{DynamicResource LpWindowFgBrush}" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtConfirmDetail" TextWrapping="Wrap" Foreground="{DynamicResource LpWindowFgBrush}" Opacity="0.7" FontSize="13" LineHeight="18"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button x:Name="BtnDeny" Content="Deny" Click="BtnDeny_Click" Style="{StaticResource LpSecondaryActionButtonStyle}" Margin="0,0,12,0"/>
                            <Button x:Name="BtnApprove" Content="Approve" Click="BtnApprove_Click" Style="{StaticResource LpPrimaryActionButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 🚀 Floating Pill HUD -->
                <Border x:Name="InputHudBorder" Background="{DynamicResource LpMenuBgBrush}" CornerRadius="6" Padding="4" Effect="{StaticResource LpGhostShadow}"
                        BorderBrush="{DynamicResource LpMenuBorderBrush}" BorderThickness="1">
                    <Grid>
                        <TextBox x:Name="TxtInput" Style="{StaticResource ChatInputStyle}" MinHeight="48" MaxHeight="200" 
                                 Padding="18,12,100,12" AcceptsReturn="True" TextWrapping="Wrap" PreviewKeyDown="TxtInput_PreviewKeyDown"
                                 FontSize="14"
                                 IsEnabled="{Binding IsInputEnabled}"
                                 Opacity="{Binding InputOpacity}"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8">
                            <Button x:Name="BtnQuickActions" Style="{StaticResource IconButtonStyle}" Click="BtnQuickActions_Click" Margin="0,0,6,0" Width="32" Height="32">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16" Opacity="0.7"/>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="QuickActionsMenu" Style="{StaticResource ThemedContextMenuStyle}">
                                        <MenuItem Header="Explain Code" Tag="explain" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}"/>
                                        <MenuItem Header="Refactor Code" Tag="refactor" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}"/>
                                        <MenuItem Header="Generate Documentation" Tag="document" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}"/>
                                        <MenuItem Header="Review Code" Tag="review" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}"/>
                                        <MenuItem Header="Fix Issues" Tag="fix" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}"/>
                                        <MenuItem Header="Generate Unit Tests" Tag="test" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                             <Button x:Name="BtnSend" Style="{StaticResource LpSendButtonStyle}" Click="BtnSend_Click" Width="30" Height="30">
                                <Path x:Name="BtnSendIcon" Data="M3.4,20.4l17.45-7.48c0.81-0.35,0.81-1.49,0-1.84L3.4,3.6C2.71,3.3,2,3.8,2,4.55l1.6,7.45L2,19.45C2,20.2,2.71,20.7,3.4,20.4z" 
                                      Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="2,0,0,0"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <TextBlock Text="Enter to send · Shift+Enter for newline"
                           Foreground="{DynamicResource LpMutedFgBrush}"
                           FontSize="10"
                           Margin="10,8,10,0"
                           Opacity="0.8"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
